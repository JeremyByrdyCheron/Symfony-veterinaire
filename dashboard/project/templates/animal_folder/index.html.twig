{% extends 'base.html.twig' %}

{% block title %}AnimalFolder index
{% endblock %}

{% block body %}
	<h1>AnimalFolder index</h1>

	<table class="table">
		<thead>
			<tr>
				<th>Id</th>
				<th>Name</th>
				<th>Age</th>
				<th>InscriptionDate</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for animal_folder in animal_folders %}
				<tr>
					<td>{{ animal_folder.id }}</td>
					<td>{{ animal_folder.name }}</td>
					<td>{{ animal_folder.animal }}</td>
					<td>{{ animal_folder.age }}</td>
					<td>{{ animal_folder.inscriptionDate ? animal_folder.inscriptionDate|date('Y-m-d') : '' }}</td>
					<td>
						<a href="{{ path('app_animal_folder_show', {'id': animal_folder.id}) }}">show</a>
						<a href="{{ path('app_animal_folder_edit', {'id': animal_folder.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a href="{{ path('app_animal_folder_new') }}">Create new</a>
{% endblock %}
