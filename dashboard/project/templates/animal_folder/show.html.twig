{% extends 'base.html.twig' %}

{% block title %}Dossier
{% endblock %}

{% block body %}
	<h1>Dossier</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Nom</th>
				<td>{{ animal_folder.name }}</td>
			</tr>
			<tr>
				<th>Âge</th>
				<td>{{ animal_folder.age }}</td>
			</tr>
			<tr>
				<th>Date d'inscription</th>
				<td>{{ animal_folder.inscriptionDate ? animal_folder.inscriptionDate|date('Y-m-d') : '' }}</td>
			</tr>
			<tr>
				<td>
					Animal
				</td>
				<td>{{ animal_folder.animal }}</td>
			</tr>
		</tbody>
	</table>

	<a class="btn" href="{{ path('app_animal_folder_index') }}">Retour à la liste</a>

	<a class="btn" href="{{ path('app_animal_folder_edit', {'id': animal_folder.id}) }}">Modifier</a>

	{{ include('animal_folder/_delete_form.html.twig') }}
{% endblock %}
