{% extends 'base.html.twig' %}

{% block title %}AnimalFolder
{% endblock %}

{% block body %}
	<h1>AnimalFolder</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ animal_folder.id }}</td>
			</tr>
			<tr>
				<th>Name</th>
				<td>{{ animal_folder.name }}</td>
			</tr>
			<tr>
				<th>Age</th>
				<td>{{ animal_folder.age }}</td>
			</tr>
			<tr>
				<th>InscriptionDate</th>
				<td>{{ animal_folder.inscriptionDate ? animal_folder.inscriptionDate|date('Y-m-d') : '' }}</td>
			</tr>
			<tr>
				<td>
					Animal
				</td>
				<td>{{ animal_folder.animal }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('app_animal_folder_index') }}">back to list</a>

	<a href="{{ path('app_animal_folder_edit', {'id': animal_folder.id}) }}">edit</a>

	{{ include('animal_folder/_delete_form.html.twig') }}
{% endblock %}
