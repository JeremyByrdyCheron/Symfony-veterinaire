{% extends 'base.html.twig' %}

{% block title %}Dossier animal{% endblock %}

{% block body %}
<h1>Dossier animal</h1>

<div class="card" style="max-width: 600px;">
    <table>
        <tbody>
            <tr><th>Nom du propriétaire</th><td>{{ animal_folder.name }}</td></tr>
            <tr><th>Animal</th><td>{{ animal_folder.animal }}</td></tr>
            <tr><th>Âge</th><td>{{ animal_folder.age }} ans</td></tr>
            <tr><th>Date d'inscription</th><td>{{ animal_folder.inscriptionDate ? animal_folder.inscriptionDate|date('d/m/Y') : '' }}</td></tr>
        </tbody>
    </table>
</div>

<a class="btn btn-outline" href="{{ path('app_animal_folder_index') }}">← Retour à la liste</a>
<a class="btn" href="{{ path('app_animal_folder_edit', {'id': animal_folder.id}) }}" style="margin-left: 0.5rem;">✏️ Modifier</a>
{{ include('animal_folder/_delete_form.html.twig') }}
{% endblock %}
