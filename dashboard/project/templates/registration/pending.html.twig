{% extends 'base.html.twig' %}

{% block title %}Compte en attente{% endblock %}

{% block body %}
<div class="pending-page">
    <div class="pending-icon">⏳</div>
    <h1>Compte en attente de validation</h1>
    <p>Votre compte a bien été créé et est actuellement en cours de validation par le <strong>Ministère de la Santé</strong>.</p>
    <p>Vous recevrez un email dès que votre accès sera activé.</p>
    <a class="btn btn-outline" href="{{ path('app_logout') }}">Se déconnecter</a>
</div>
{% endblock %}
