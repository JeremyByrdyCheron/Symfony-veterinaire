{% extends 'base.html.twig' %}

{% block title %}Inscription — VetCare{% endblock %}

{% block body %}
<div style="max-width: 520px; margin: 3rem auto;">
    <div class="card">
        <div class="card-header" style="text-align:center; font-size: 1.2rem;">🐾 Créer un compte vétérinaire</div>

        {{ form_start(registrationForm) }}
            {{ form_row(registrationForm.name) }}
            {{ form_row(registrationForm.firstname) }}
            {{ form_row(registrationForm.email) }}
            {{ form_row(registrationForm.plainPassword) }}
            {{ form_row(registrationForm.phoneNumber) }}
            {{ form_row(registrationForm.address) }}
            {{ form_row(registrationForm.licenseNumber) }}
            {{ form_widget(registrationForm.submit) }}
        {{ form_end(registrationForm) }}

        <p style="margin-top: 1rem; text-align:center;">
            Déjà un compte ? <a href="{{ path('app_login') }}">Connexion</a>
        </p>
    </div>
</div>
{% endblock %}
