{% extends 'base.html.twig' %}

{% block title %}Connexion — VetCare{% endblock %}

{% block body %}
<div style="max-width: 420px; margin: 4rem auto;">
    <div class="card">
        <div class="card-header" style="text-align:center; font-size: 1.2rem;">🐾 Connexion VetCare</div>

        {% if error %}
            <div class="alert alert-danger">{{ error.messageKey|trans }}</div>
        {% endif %}

        <form method="post">
            <label for="email">Email</label>
            <input type="email" id="email" name="_username" value="{{ last_username }}" placeholder="veto@cabinet.fr" required>

            <label for="password">Mot de passe</label>
            <input type="password" id="password" name="_password" placeholder="••••••••" required>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">
            <button type="submit" class="btn" style="width: 100%; justify-content: center; margin-top: 0.5rem;">Se connecter</button>
        </form>

        <p style="margin-top: 1rem; text-align:center;">
            Pas encore de compte ? <a href="{{ path('app_register') }}">Inscription</a>
        </p>
        <p style="text-align:center;">
            <a href="{{ path('app_forgot_password_request') }}">Mot de passe oublié ?</a>
        </p>
    </div>
</div>
{% endblock %}
