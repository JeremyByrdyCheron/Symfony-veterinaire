{% extends 'base.html.twig' %}

{% block body %}
<h1>Demandes de rendez-vous</h1>

{% for request in requests %}
<div class="card mb-3">
    <div class="card-body">
        <h5>{{ request.animal }} — {{ request.type.value }}</h5>
        <p>Client : {{ request.email }}</p>
        <p>Date souhaitée : {{ request.wantedDate|date('d/m/Y') }}</p>
        <p>{{ request.description }}</p>

        <form method="post" action="{{ path('app_notification_accept', {id: request.id}) }}" style="display:inline">
            <button class="btn btn-success">✅ Accepter</button>
        </form>

        <form method="post" action="{{ path('app_notification_refuse', {id: request.id}) }}" style="display:inline">
            <button class="btn btn-danger">❌ Refuser</button>
        </form>

        <form method="post" action="{{ path('app_notification_reschedule', {id: request.id}) }}" style="display:inline">
            <input type="date" name="new_date" required>
            <button class="btn btn-warning">📅 Décaler</button>
        </form>
    </div>
</div>
{% else %}
    <p>Aucune demande en attente.</p>
{% endfor %}
{% endblock %}