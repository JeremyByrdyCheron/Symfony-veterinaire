{% extends 'base.html.twig' %}

{% block title %}Appointment
{% endblock %}

{% block body %}
	<h1>Appointment</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Id</th>
				<td>{{ appointment.id }}</td>
			</tr>
			<tr>
				<th>Type</th>
				<td>{{ appointment.type.name }}</td>
			</tr>
			<tr>
				<th>Email</th>
				<td>{{ appointment.email }}</td>
			</tr>
			<tr>
				<th>Animal</th>
				<td>{{ appointment.animal }}</td>
			</tr>
			<tr>
				<th>Status</th>
				<td>{{ appointment.status.name }}</td>
			</tr>
			<tr>
				<th>SubmittedDate</th>
				<td>{{ appointment.submittedDate ? appointment.submittedDate|date('Y-m-d') : '' }}</td>
			</tr>
			<tr>
				<th>Description</th>
				<td>{{ appointment.description }}</td>
			</tr>
			<tr>
				<th>WantedDate</th>
				<td>{{ appointment.wantedDate ? appointment.wantedDate|date('Y-m-d') : '' }}</td>
			</tr>
			<tr>
				<th>Lastname</th>
				<td>{{ appointment.lastname }}</td>
			</tr>
			<tr>
				<th>Firstname</th>
				<td>{{ appointment.firstname }}</td>
			</tr>
			<tr>
				<th>PhoneNumber</th>
				<td>{{ appointment.phoneNumber }}</td>
			</tr>
		</tbody>
	</table>

	<a href="{{ path('app_appointment_index') }}">back to list</a>

	<a href="{{ path('app_appointment_edit', {'id': appointment.id}) }}">edit</a>

	{{ include('appointment/_delete_form.html.twig') }}
{% endblock %}
