{% extends 'base.html.twig' %}

{% block title %}Document index
{% endblock %}

{% block body %}
	<h1>Document index</h1>

	<table class="table">
		<thead>
			<tr>
				<th>Pdf</th>
				<th>UpdatedAt</th>
				<th>actions</th>
			</tr>
		</thead>
		<tbody>
			{% for document in documents %}
				<tr>
					<td>
						<a href="{{ asset('uploads/pdfs/' ~ document.pdf) }}" download>
							Télécharger le PDF
						</a>
					</td>
					<td>{{ document.updatedAt ? document.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
					<td>
						<a href="{{ path('app_document_show', {'id': document.id}) }}">show</a>
						<a href="{{ path('app_document_edit', {'id': document.id}) }}">edit</a>
					</td>
				</tr>
			{% else %}
				<tr>
					<td colspan="5">no records found</td>
				</tr>
			{% endfor %}
		</tbody>
	</table>

	<a href="{{ path('app_document_new') }}">Create new</a>
{% endblock %}
