{% extends 'base.html.twig' %}

{% block title %}Document{% endblock %}

{% block body %}
<h1>Document</h1>

<div class="card" style="max-width: 600px;">
    <table>
        <tbody>
            {% if document.appointmentId %}
                <tr><th>Client</th><td>{{ document.appointmentId.firstname }} {{ document.appointmentId.lastname }}</td></tr>
                <tr><th>Animal</th><td>{{ document.appointmentId.animalFolderId ? document.appointmentId.animalFolderId.name : '—' }}</td></tr>
                <tr><th>Type de RDV</th><td>{{ document.appointmentId.type.value }}</td></tr>
                <tr><th>Date RDV</th><td>{{ document.appointmentId.wantedDate|date('d/m/Y') }}</td></tr>
            {% endif %}
            <tr><th>Modifié le</th><td>{{ document.updatedAt ? document.updatedAt|date('d/m/Y H:i') : '—' }}</td></tr>
            <tr>
                <th>PDF</th>
                <td><a href="{{ asset('uploads/pdfs/' ~ document.pdf) }}" download class="btn btn-sm">⬇️ Télécharger</a></td>
            </tr>
        </tbody>
    </table>
</div>

<a class="btn btn-outline" href="{{ path('app_document_index') }}">← Retour à la liste</a>
<a class="btn" href="{{ path('app_document_edit', {'id': document.id}) }}" style="margin-left: 0.5rem;">✏️ Modifier</a>
{{ include('document/_delete_form.html.twig') }}
{% endblock %}
