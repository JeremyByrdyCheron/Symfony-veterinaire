{% extends 'base.html.twig' %}

{% block title %}Document
{% endblock %}

{% block body %}
	<h1>Document</h1>

	<table class="table">
		<tbody>
			<tr>
				<th>Pdf</th>
				<td>
					<a class="btn" href="{{ asset('uploads/pdfs/' ~ document.pdf) }}" download>
						Télécharger le PDF
					</a>
				</td>
			</tr>
			<tr>
				<th>Modifier le</th>
				<td>{{ document.updatedAt ? document.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
			</tr>
		</tbody>
	</table>

	<a class="btn" href="{{ path('app_document_index') }}">Retour à la liste</a>

	<a class="btn" href="{{ path('app_document_edit', {'id': document.id}) }}">Modifier</a>

	{{ include('document/_delete_form.html.twig') }}
{% endblock %}
