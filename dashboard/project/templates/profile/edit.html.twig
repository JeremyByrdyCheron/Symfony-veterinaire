{% extends 'base.html.twig' %}

{% block title %}Modifier mon profil{% endblock %}

{% block body %}
<h1>Modifier mon profil</h1>

<div class="card" style="max-width: 520px;">
    {{ form_start(form) }}
        {{ form_row(form.name) }}
        {{ form_row(form.firstname) }}
        {{ form_row(form.email) }}
        {{ form_row(form.phoneNumber) }}
        {{ form_row(form.address) }}
        <button type="submit" class="btn">💾 Enregistrer</button>
    {{ form_end(form) }}
</div>

<a class="btn btn-outline" href="{{ path('profile') }}">Annuler</a>
<a class="btn btn-outline" href="{{ path('app_forgot_password_request') }}" style="margin-left: 0.5rem;">🔑 Réinitialiser le mot de passe</a>
{% endblock %}
