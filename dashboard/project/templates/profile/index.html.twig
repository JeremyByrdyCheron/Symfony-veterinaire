{% extends 'base.html.twig' %}

{% block title %}Mon profil
{% endblock %}

{% block body %}
	<h1>Mon profil</h1>

	<p>
		Nom :
		{{ user.name }}</p>
	<p>
		Prénom :
		{{ user.firstname }}</p>
	<p>
		Email :
		{{ user.email }}</p>
	<p>
		Téléphone :
		{{ user.phoneNumber }}</p>
	<p>
		Adresse :
		{{ user.address }}</p>
	<p>
		Numéro de licence :
		{{ user.licenseNumber }}</p>

	{% for message in app.flashes('success') %}
		<p>{{ message }}</p>
	{% endfor %}

	{% for message in app.flashes('error') %}
		<p>{{ message }}</p>
	{% endfor %}

	<a href="{{ path('profile-edit') }}">Modifier mon profil</a>

	<form method="post" action="{{ path('profile-delete') }}">
		<input type="hidden" name="_token" value="{{ csrf_token('delete_account') }}">
		<button type="submit" onclick="return confirm('Supprimer définitivement votre compte ?')">
			Supprimer mon compte
		</button>
	</form>
{% endblock %}
